# Stage 1: Frontend build
ARG BASE_IMAGE=covscript-base:latest
FROM node:20-alpine AS frontend
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY src/ ./src/
COPY public/ ./public/
COPY index.html vite.config.js ./
RUN npm run build

# Stage 2: Web server
FROM ${BASE_IMAGE}
WORKDIR /app
COPY configs/web.json config.json
RUN sed -i 's|"wwwroot": "wwwroot"|"wwwroot": "/app/wwwroot"|' config.json
COPY servers/web.ecs server.ecs
COPY --from=frontend /app/wwwroot/ /app/wwwroot/

# Compile web server (netutils is already installed as a package in the base image).
RUN ecs -u UTF8 -f -o . server.ecs && \
    rm -f server.ecs

EXPOSE 8080
CMD ["cs", "/app/server.csc", "config.json", "--sandbox_host", "sandbox", "--sandbox_port", "8088"]
